    {
      "parameters": {
        "functionCode": "const salesItems = $items(\"Read Sales Sheet\");\nconst inventoryItems = $items(\"Read Inventory Sheet\");\n\nreturn [{\n  json: {\n    sales: salesItems.map(i => i.json),\n    inventory: inventoryItems.map(i => i.json),\n    reportDate: new Date().toISOString().split('T')[0]\n  }\n}];\n"
      },
      "id": "636c171f-e723-4223-b520-89cdd4b43837",
      "name": "Combine Data",
      "type": "n8n-nodes-base.function",
