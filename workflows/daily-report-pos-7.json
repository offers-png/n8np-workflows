    {
      "parameters": {
        "jsCode": "return [\n  {\n    json: {\n      date: $json.reportDate,\n      totalRevenue: $json.totalRevenue,\n      estimatedProfit: $json.estimatedProfit,\n\n      topSellingItems: ($json.topSellingItems || [])\n        .map(i => i.name)\n        .join(\", \"),\n\n      slowMovingItems: ($json.slowMovingItems || [])\n        .map(i => i.name)\n        .join(\", \"),\n\n      lowStockWarnings: ($json.lowStockWarnings || [])\n        .map(i => `${i.name} (qty: ${i.quantity}, min: ${i.minStock})`)\n        .join(\", \"),\n\n      recommendations: ($json.recommendations || []).join(\" | \")\n    }\n  }\n];\n"
