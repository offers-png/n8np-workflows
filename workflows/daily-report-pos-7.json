      "position": [
        560,
        304
      ]
    },
    {
      "parameters": {
        "functionCode": "const { sales, inventory, reportDate } = items[0].json;\n\nreturn [\n  {\n    json: {\n      messages: [\n        {\n          role: \"system\",\n          content: `\nYou are an AI business analyst.\nYou MUST return ONLY valid JSON.\nDo NOT include explanations, markdown, or text.\n\nThe JSON MUST contain ALL of the following fields:\n\n{\n  \"reportDate\": \"string\",\n  \"totalRevenue\": number,\n  \"estimatedProfit\": number,\n  \"topSellingItems\": array,\n  \"slowMovingItems\": array,\n  \"lowStockWarnings\": array,\n  \"recommendations\": array\n}\n          `.trim()\n        },\n        {\n          role: \"user\",\n          content: JSON.stringify({\n            reportDate,\n            sales,\n            inventory\n          })\n        }\n      ]\n    }\n  }\n];\n"
      },
      "id": "e74c72d6-143f-4eb0-b39a-25ada96df5f6",
